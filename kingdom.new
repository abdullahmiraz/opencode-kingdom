#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# 👑 OpenCode Kingdom — Single CLI to Rule All Projects
# ============================================================
# Usage:
#   ./kingdom                        Show help
#   ./kingdom init [path]            Bootstrap a project
#   ./kingdom link <path>            Link existing project
#   ./kingdom promote <agent-file>   Promote agent → kingdom
#   ./kingdom promote --role king    Promote as royal agent
#   ./kingdom backup                 Mirror kingdom → backup/
#   ./kingdom restore                Restore kingdom from backup/
#   ./kingdom sync [path]            Push updates to project(s)
#   ./kingdom status                 Show version + linked projects
#   ./kingdom version                Show version number
# ============================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KINGDOM_DIR="$SCRIPT_DIR"
BACKUP_DIR="$KINGDOM_DIR/backup"
KINGDOM_VERSION="1.1.0"

# ─── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; PURPLE='\033[0;35m'; BOLD='\033[1m'
NC='\033[0m' # No Color

info()  { echo -e "${CYAN}ℹ${NC}  $1"; }
ok()    { echo -e "${GREEN}✅${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC}  $1"; }
err()   { echo -e "${RED}❌${NC} $1"; }
header(){ echo -e "\n${BOLD}${PURPLE}═══ $1 ═══${NC}\n"; }

# ─── Help ─────────────────────────────────────────────────────
show_help() {
    echo -e "${BOLD}👑 OpenCode Kingdom v${KINGDOM_VERSION}${NC}"
    echo "Single CLI to manage all your OpenCode projects."
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "  ./kingdom <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo -e "  ${GREEN}init${NC}       [path]           Bootstrap a new project with kingdom agents"
    echo -e "  ${GREEN}link${NC}       <path>           Link an existing project under the kingdom"
    echo -e "  ${GREEN}promote${NC}    <agent-file>     Promote a project agent to the kingdom"
    echo -e "  ${GREEN}backup${NC}                      Mirror kingdom to backup/"
    echo -e "  ${GREEN}restore${NC}                     Restore kingdom from backup/"
    echo -e "  ${GREEN}sync${NC}       [path]           Push kingdom updates to project(s)"
    echo -e "  ${GREEN}status${NC}                      Show kingdom version + linked projects"
    echo -e "  ${GREEN}version${NC}                     Show version number"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "  ./kingdom init ~/projects/my-app"
    echo "  ./kingdom link ."
    echo "  ./kingdom promote ./my-agent.md"
    echo "  ./kingdom sync"
    echo "  ./kingdom backup"
    echo ""
    echo -e "${BOLD}LEARN MORE${NC}"
    echo "  https://github.com/YOUR_ORG/opencode-kingdom"
}

# ─── Command: version ─────────────────────────────────────────
cmd_version() {
    echo "👑 OpenCode Kingdom v${KINGDOM_VERSION}"
}

# ─── Command: status ──────────────────────────────────────────
cmd_status() {
    header "Kingdom Status"
    echo "Version: ${KINGDOM_VERSION}"
    echo "Path:    ${KINGDOM_DIR}"
    echo ""

    # Count agents
    KING_COUNT=$(find "$KINGDOM_DIR/king" -name '*.md' 2>/dev/null | wc -l)
    KNIGHT_COUNT=$(find "$KINGDOM_DIR/knights" -name '*.md' 2>/dev/null | wc -l)
    echo -e "${BOLD}Royal Agents:${NC} ${KING_COUNT}"
    for f in "$KINGDOM_DIR/king/"*.md; do
        echo "  👑 $(basename "$f" .md)"
    done
    echo ""
    echo -e "${BOLD}Knights:${NC} ${KNIGHT_COUNT}"
    for f in "$KINGDOM_DIR/knights/"*.md; do
        echo "  🛡️  $(basename "$f" .md)"
    done

    # Check backup status
    echo ""
    if [ -f "$BACKUP_DIR/BACKUP_MANIFEST.txt" ]; then
        BACKUP_DATE=$(head -2 "$BACKUP_DIR/BACKUP_MANIFEST.txt" | grep "Backup Date" | cut -d: -f2- | xargs)
        ok "Backup exists (last: ${BACKUP_DATE})"
    else
        warn "No backup found. Run: ./kingdom backup"
    fi

    # Find linked projects
    echo ""
    echo -e "${BOLD}Linked Projects:${NC}"
    LINKED=0
    # Check some common locations + the kingdom-link.txt files
    while IFS= read -r -d '' linkfile; do
        PROJECT_DIR="$(dirname "$(dirname "$linkfile")")"
        PROJECT_NAME=$(basename "$PROJECT_DIR")
        KV=$(grep "KINGDOM_VERSION" "$linkfile" 2>/dev/null | cut -d: -f2 | xargs || echo "?")
        if [ "$KV" = "$KINGDOM_VERSION" ]; then
            ok "${PROJECT_NAME} (version: ${KV})"
        else
            warn "${PROJECT_NAME} (version: ${KV} — out of sync)"
        fi
        LINKED=$((LINKED + 1))
    done < <(find "$HOME" -maxdepth 6 -path "*/.opencode/kingdom/kingdom-link.txt" -print0 2>/dev/null || true)
    
    # Also check the projects/ registry
    if [ -d "$KINGDOM_DIR/projects" ]; then
        for overlay in "$KINGDOM_DIR/projects/"*/; do
            PNAME=$(basename "$overlay")
            if [ -d "$overlay" ]; then
                ok "${PNAME} (registered in projects/)"
                LINKED=$((LINKED + 1))
            fi
        done
    fi

    if [ "$LINKED" -eq 0 ]; then
        warn "No linked projects found."
    fi
    echo ""
    echo -e "${BOLD}📦 ${LINKED} total project(s) linked${NC}"
}

# ─── Command: backup ──────────────────────────────────────────
cmd_backup() {
    header "Backup"
    
    # Validate kingdom integrity
    if [ ! -d "$KINGDOM_DIR/king" ] || [ ! -d "$KINGDOM_DIR/knights" ]; then
        err "Kingdom directories incomplete"
        exit 1
    fi

    # Backup king agents
    info "Backing up royal agents..."
    rm -rf "$BACKUP_DIR/king" && cp -r "$KINGDOM_DIR/king" "$BACKUP_DIR/king"
    ok "$(find "$KINGDOM_DIR/king" -name '*.md' | wc -l) royal agents"

    # Backup knights
    info "Backing up knights..."
    rm -rf "$BACKUP_DIR/knights" && cp -r "$KINGDOM_DIR/knights" "$BACKUP_DIR/knights"
    ok "$(find "$KINGDOM_DIR/knights" -name '*.md' | wc -l) knights"

    # Backup root configs
    for f in opencode.kingdom.json RULES.kingdom.md; do
        [ -f "$KINGDOM_DIR/$f" ] && cp "$KINGDOM_DIR/$f" "$BACKUP_DIR/$f" && ok "$f backed up"
    done

    # Backup scripts
    rm -rf "$BACKUP_DIR/scripts" && cp -r "$KINGDOM_DIR/scripts" "$BACKUP_DIR/scripts" 2>/dev/null || true

    # Backup projects registry
    rm -rf "$BACKUP_DIR/projects" && cp -r "$KINGDOM_DIR/projects" "$BACKUP_DIR/projects" 2>/dev/null || true

    # Write manifest
    cat > "$BACKUP_DIR/BACKUP_MANIFEST.txt" << EOF
BACKUP DATE: $(date -u '+%Y-%m-%d %H:%M:%S UTC')
KINGDOM_VERSION: ${KINGDOM_VERSION}
CONTENTS: king (${KING_COUNT:-0}), knights (${KNIGHT_COUNT:-0}), configs, scripts
EOF

    ok "Backup complete → ${BACKUP_DIR}"
}

# ─── Command: restore ─────────────────────────────────────────
cmd_restore() {
    header "Restore from Backup"

    if [ ! -d "$BACKUP_DIR/king" ] && [ ! -d "$BACKUP_DIR/knights" ]; then
        err "No backup found at ${BACKUP_DIR}"
        exit 1
    fi

    if [ -d "$BACKUP_DIR/king" ]; then
        rm -rf "$KINGDOM_DIR/king" && cp -r "$BACKUP_DIR/king" "$KINGDOM_DIR/king"
        ok "Royal agents restored"
    fi

    if [ -d "$BACKUP_DIR/knights" ]; then
        rm -rf "$KINGDOM_DIR/knights" && cp -r "$BACKUP_DIR/knights" "$KINGDOM_DIR/knights"
        ok "Knights restored"
    fi

    for f in opencode.kingdom.json RULES.kingdom.md scripts; do
        [ -e "$BACKUP_DIR/$f" ] && cp -r "$BACKUP_DIR/$f" "$KINGDOM_DIR/$f" && ok "$f restored"
    done

    ok "Kingdom regenerated from backup!"
    info "Run: ./kingdom sync  (to push to all projects)"
}

# ─── Command: init ────────────────────────────────────────────
cmd_init() {
    local PROJECT_PATH="${1:-}"

    if [ -z "$PROJECT_PATH" ]; then
        # Try current directory
        if [ -f "package.json" ] || [ -f "Cargo.toml" ] || [ -f "go.mod" ] || [ -f "pyproject.toml" ]; then
            PROJECT_PATH="."
        else
            err "No project detected. Specify a path: ./kingdom init ~/projects/my-app"
            exit 1
        fi
    fi

    # Resolve absolute path
    PROJECT_PATH="$(cd "$PROJECT_PATH" 2>/dev/null && pwd || echo "$PROJECT_PATH")"
    PROJECT_NAME="$(basename "$PROJECT_PATH")"
    OPENCODE_DIR="$PROJECT_PATH/.opencode"

    header "Init: ${PROJECT_NAME}"
    info "Path: ${PROJECT_PATH}"

    # Detect project type for default commands
    if [ -f "$PROJECT_PATH/package.json" ]; then
        TYPECHECK_CMD="npx tsc --noEmit"
        BUILD_CMD="npm run build"
    elif [ -f "$PROJECT_PATH/Cargo.toml" ]; then
        TYPECHECK_CMD="cargo check"
        BUILD_CMD="cargo build"
    elif [ -f "$PROJECT_PATH/go.mod" ]; then
        TYPECHECK_CMD="go vet ./..."
        BUILD_CMD="go build ./..."
    elif [ -f "$PROJECT_PATH/pyproject.toml" ]; then
        TYPECHECK_CMD="mypy ."
        BUILD_CMD="python -m build"
    else
        TYPECHECK_CMD="npx tsc --noEmit"
        BUILD_CMD="npm run build"
        warn "Unknown project type — using default commands (npm/tsc)"
    fi

    # Check if .opencode exists
    if [ -d "$OPENCODE_DIR" ]; then
        if [ -f "$OPENCODE_DIR/kingdom/kingdom-link.txt" ]; then
            warn "Project is already linked to the kingdom."
            info "Run: ./kingdom sync ${PROJECT_PATH}  (to update)"
            exit 0
        fi
        warn ".opencode directory already exists — will merge kingdom agents"
    fi

    # Create structure
    mkdir -p "$OPENCODE_DIR/agents" "$OPENCODE_DIR/memory" "$OPENCODE_DIR/kingdom"

    # Write kingdom link
    cat > "$OPENCODE_DIR/kingdom/kingdom-link.txt" << EOF
KINGDOM_VERSION: ${KINGDOM_VERSION}
LINKED_DATE: $(date '+%Y-%m-%d')
KINGDOM_PATH: ${KINGDOM_DIR}
INIT_CMD: ${KINGDOM_DIR}/kingdom init ${PROJECT_PATH}
SYNC_CMD: ${KINGDOM_DIR}/kingdom sync ${PROJECT_PATH}
EOF
    ok "Kingdom link created"

    # Copy royal agents
    if [ -d "$KINGDOM_DIR/king" ]; then
        cp -r "$KINGDOM_DIR/king/"* "$OPENCODE_DIR/agents/"
        ok "$(find "$KINGDOM_DIR/king" -name '*.md' | wc -l) royal agents copied"
    fi

    # Copy knights
    if [ -d "$KINGDOM_DIR/knights" ]; then
        cp -r "$KINGDOM_DIR/knights/"* "$OPENCODE_DIR/agents/"
        ok "$(find "$KINGDOM_DIR/knights" -name '*.md' | wc -l) knights copied"
    fi

    # Copy RULES
    if [ -f "$KINGDOM_DIR/RULES.kingdom.md" ]; then
        # Check if project already has a RULES.md — preserve it, merge kingdom header
        if [ -f "$OPENCODE_DIR/RULES.md" ]; then
            warn "RULES.md exists — preserving project-specific rules"
            info "Refer to ${KINGDOM_DIR}/RULES.kingdom.md for universal kingdom law"
        else
            cp "$KINGDOM_DIR/RULES.kingdom.md" "$OPENCODE_DIR/RULES.md"
            ok "RULES.md copied"
        fi
    fi

    # Generate opencode.json (simplified — just kingdom agents + placeholders)
    if [ ! -f "$PROJECT_PATH/opencode.json" ]; then
        cat > "$PROJECT_PATH/opencode.json" << JSONEOF
{
  "\$schema": "https://opencode.ai/config.json",
  "_kingdom_version": "${KINGDOM_VERSION}",
  "_generated": "$(date '+%Y-%m-%d')",
  "plugin": [
    "oh-my-openagent",
    "@capybearista/opencode-adversarial-review@latest",
    "@capybearista/opencode-agents-loader@latest",
    "@capybearista/opencode-agent-prompt-inheritance@latest"
  ],
  "instructions": [".opencode/RULES.md"],
  "agent": {
    "king-sisyphus": {
      "description": "👑 KING: Always-running supreme orchestrator.",
      "mode": "primary",
      "prompt": "Read .opencode/RULES.md and .opencode/agents/king-sisyphus.md. Invoke @queen-metis for context, @prince-of-memory for state, @prince-of-code for building, @prince-of-git for commits."
    },
    "queen-metis": {
      "description": "👸 QUEEN METIS: Wisdom, context, self-improvement.",
      "mode": "subagent",
      "prompt": "Read .opencode/agents/queen-metis.md. I use @context-loader and @context-checker."
    },
    "prince-of-memory": {
      "description": "🫅 PRINCE OF MEMORY: State, tasks, decisions.",
      "mode": "subagent",
      "prompt": "Read .opencode/agents/prince-of-memory.md. I manage @task-tracker and @state-writer."
    },
    "prince-of-code": {
      "description": "🫅 PRINCE OF CODE: Building, quality.",
      "mode": "subagent",
      "prompt": "Read .opencode/agents/prince-of-code.md. I use @component-builder, @data-layer-builder, @page-assembler, @quality-gate."
    },
    "prince-of-git": {
      "description": "🫅 PRINCE OF GIT: Commit discipline.",
      "mode": "subagent",
      "prompt": "Read .opencode/agents/prince-of-git.md. I use @git-manager, @change-inspector, @commit-executor."
    },
    "context-loader": { "description": "Reads memory files.", "mode": "subagent", "prompt": "Read .opencode/agents/context-loader.md. Serve @queen-metis." },
    "context-checker": { "description": "Validates flows.", "mode": "subagent", "prompt": "Read .opencode/agents/context-checker.md. Serve @queen-metis." },
    "task-tracker": { "description": "Manages todos.", "mode": "subagent", "prompt": "Read .opencode/agents/task-tracker.md. Serve @prince-of-memory." },
    "state-writer": { "description": "Updates state.md.", "mode": "subagent", "prompt": "Read .opencode/agents/state-writer.md. Serve @prince-of-memory." },
    "component-builder": { "description": "Builds UI components.", "mode": "subagent", "prompt": "Read .opencode/agents/component-builder.md. Serve @prince-of-code." },
    "data-layer-builder": { "description": "Builds data layer.", "mode": "subagent", "prompt": "Read .opencode/agents/data-layer-builder.md. Serve @prince-of-code." },
    "page-assembler": { "description": "Assembles pages.", "mode": "subagent", "prompt": "Read .opencode/agents/page-assembler.md. Serve @prince-of-code." },
    "quality-gate": { "description": "Typecheck + build.", "mode": "subagent", "prompt": "Read .opencode/agents/quality-gate.md. Serve @prince-of-code." },
    "git-manager": { "description": "Git workflow.", "mode": "subagent", "prompt": "Read .opencode/agents/git-manager.md. Serve @prince-of-git." },
    "change-inspector": { "description": "Analyzes changes.", "mode": "subagent", "prompt": "Read .opencode/agents/change-inspector.md. Serve @prince-of-git." },
    "commit-executor": { "description": "Executes commits.", "mode": "subagent", "prompt": "Read .opencode/agents/commit-executor.md. Serve @prince-of-git." }
  }
}
JSONEOF
        ok "opencode.json generated"
    else
        ok "opencode.json exists — skipping (edit manually to add kingdom agents)"
        info "See: ${KINGDOM_DIR}/opencode.kingdom.json for reference"
    fi

    # Create initial memory files
    if [ ! -f "$OPENCODE_DIR/memory/state.md" ]; then
        cat > "$OPENCODE_DIR/memory/state.md" << EOF
# ${PROJECT_NAME} — Project State
**Last Updated:** $(date '+%Y-%m-%d')
**Kingdom v${KINGDOM_VERSION}**

## Build Status
- Typecheck: ⏳ Not yet run
- Build: ⏳ Not yet run
EOF
    fi

    if [ ! -f "$OPENCODE_DIR/memory/tasks.md" ]; then
        cat > "$OPENCODE_DIR/memory/tasks.md" << EOF
# Tasks — ${PROJECT_NAME}

## Current Sprint
- [ ] [P0] Verify project setup — typecheck + build passing
EOF
    fi

    if [ ! -f "$OPENCODE_DIR/memory/decisions.md" ]; then
        cat > "$OPENCODE_DIR/memory/decisions.md" << EOF
# Architecture Decisions — ${PROJECT_NAME}

## ADR-1: OpenCode Kingdom Integration
**Date:** $(date '+%Y-%m-%d')
**Context:** Project initialized using OpenCode Kingdom v${KINGDOM_VERSION}.
**Decision:** Using kingdom agents for orchestration.
**Status:** Accepted
EOF
    fi

    # Register in projects/
    mkdir -p "$KINGDOM_DIR/projects/${PROJECT_NAME}"
    cat > "$KINGDOM_DIR/projects/${PROJECT_NAME}/registration.txt" << EOF
PROJECT_NAME: ${PROJECT_NAME}
PROJECT_PATH: ${PROJECT_PATH}
LINKED_DATE: $(date '+%Y-%m-%d')
KINGDOM_VERSION: ${KINGDOM_VERSION}
EOF
    
    header "✅ ${PROJECT_NAME} initialized!"
    echo -e "   ${GREEN}Project:${NC}  ${PROJECT_PATH}"
    echo -e "   ${GREEN}Kingdom:${NC}  ${KINGDOM_DIR}"
    echo -e "   ${GREEN}Agents:${NC}   $(find "$OPENCODE_DIR/agents" -name '*.md' | wc -l) files"
    echo ""
    echo "   ${BOLD}Next:${NC}"
    echo "   1. cd ${PROJECT_PATH}"
    echo "   2. Edit .opencode/RULES.md — add architecture constraints"
    echo "   3. Add project-specific agents to .opencode/agents/"
    echo "   4. Start opencode session"
}

# ─── Command: link ────────────────────────────────────────────
cmd_link() {
    local PROJECT_PATH="${1:-}"
    
    if [ -z "$PROJECT_PATH" ]; then
        err "Usage: ./kingdom link <project-path>"
        exit 1
    fi

    PROJECT_PATH="$(cd "$PROJECT_PATH" 2>/dev/null && pwd || echo "$PROJECT_PATH")"
    
    if [ ! -d "$PROJECT_PATH/.opencode" ]; then
        err "No .opencode directory found at ${PROJECT_PATH}"
        info "Run: ./kingdom init ${PROJECT_PATH}  first"
        exit 1
    fi

    PROJECT_NAME="$(basename "$PROJECT_PATH")"
    mkdir -p "$PROJECT_PATH/.opencode/kingdom"

    cat > "$PROJECT_PATH/.opencode/kingdom/kingdom-link.txt" << EOF
KINGDOM_VERSION: ${KINGDOM_VERSION}
LINKED_DATE: $(date '+%Y-%m-%d')
KINGDOM_PATH: ${KINGDOM_DIR}
SYNC_CMD: ${KINGDOM_DIR}/kingdom sync ${PROJECT_PATH}
EOF

    # Register
    mkdir -p "$KINGDOM_DIR/projects/${PROJECT_NAME}"
    cat > "$KINGDOM_DIR/projects/${PROJECT_NAME}/registration.txt" << EOF
PROJECT_NAME: ${PROJECT_NAME}
PROJECT_PATH: ${PROJECT_PATH}
LINKED_DATE: $(date '+%Y-%m-%d')
KINGDOM_VERSION: ${KINGDOM_VERSION}
EOF

    ok "${PROJECT_NAME} linked to kingdom v${KINGDOM_VERSION}"
    info "Run: ./kingdom sync ${PROJECT_PATH}  to sync agents"
}

# ─── Command: sync ────────────────────────────────────────────
cmd_sync() {
    local SPECIFIC_PATH="${1:-}"

    header "Sync"

    COLLECT_PATHS=()
    if [ -n "$SPECIFIC_PATH" ]; then
        SPECIFIC_PATH="$(cd "$SPECIFIC_PATH" 2>/dev/null && pwd || echo "$SPECIFIC_PATH")"
        if [ -f "$SPECIFIC_PATH/.opencode/kingdom/kingdom-link.txt" ]; then
            COLLECT_PATHS+=("$SPECIFIC_PATH")
        else
            err "No kingdom link at ${SPECIFIC_PATH}"
            exit 1
        fi
    else
        # Scan for linked projects
        while IFS= read -r -d '' linkfile; do
            p="$(dirname "$(dirname "$linkfile")")"
            COLLECT_PATHS+=("$p")
        done < <(find "$HOME" -maxdepth 6 -path "*/.opencode/kingdom/kingdom-link.txt" -print0 2>/dev/null || true)
        
        # Also check projects/registry
        if [ -d "$KINGDOM_DIR/projects" ]; then
            for reg in "$KINGDOM_DIR/projects/"*/registration.txt; do
                [ -f "$reg" ] || continue
                REG_PATH=$(grep "PROJECT_PATH" "$reg" | cut -d: -f2- | xargs)
                if [ -d "$REG_PATH" ] && [ -f "$REG_PATH/.opencode/kingdom/kingdom-link.txt" ]; then
                    # Check if already in list
                    FOUND=0
                    for cp in "${COLLECT_PATHS[@]}"; do [ "$cp" = "$REG_PATH" ] && FOUND=1; done
                    [ "$FOUND" -eq 0 ] && COLLECT_PATHS+=("$REG_PATH")
                fi
            done
        fi
    fi

    if [ ${#COLLECT_PATHS[@]} -eq 0 ]; then
        warn "No linked projects found."
        info "Link one: ./kingdom link <project-path>"
        exit 0
    fi

    SYNCED=0
    for PROJECT_PATH in "${COLLECT_PATHS[@]}"; do
        PNAME="$(basename "$PROJECT_PATH")"
        echo -ne "${CYAN}${PNAME}${NC}... "
        
        LOCAL_AGENTS=()
        # Find agents that exist in project but NOT in kingdom (preserve them)
        for af in "$PROJECT_PATH/.opencode/agents/"*.md; do
            aname="$(basename "$af")"
            if [ ! -f "$KINGDOM_DIR/king/$aname" ] && [ ! -f "$KINGDOM_DIR/knights/$aname" ]; then
                LOCAL_AGENTS+=("$aname")
            fi
        done

        # Sync king agents
        if [ -d "$KINGDOM_DIR/king" ]; then
            for kf in "$KINGDOM_DIR/king/"*.md; do
                kname="$(basename "$kf")"
                SKIP=false
                for la in "${LOCAL_AGENTS[@]}"; do [ "$la" = "$kname" ] && SKIP=true; done
                $SKIP || cp "$kf" "$PROJECT_PATH/.opencode/agents/$kname"
            done
        fi

        # Sync knights
        if [ -d "$KINGDOM_DIR/knights" ]; then
            for kf in "$KINGDOM_DIR/knights/"*.md; do
                kname="$(basename "$kf")"
                SKIP=false
                for la in "${LOCAL_AGENTS[@]}"; do [ "$la" = "$kname" ] && SKIP=true; done
                $SKIP || cp "$kf" "$PROJECT_PATH/.opencode/agents/$kname"
            done
        fi

        # Update kingdom link
        cat > "$PROJECT_PATH/.opencode/kingdom/kingdom-link.txt" << EOF
KINGDOM_VERSION: ${KINGDOM_VERSION}
LINKED_DATE: $(date '+%Y-%m-%d')
KINGDOM_PATH: ${KINGDOM_DIR}
SYNC_CMD: ${KINGDOM_DIR}/kingdom sync ${PROJECT_PATH}
EOF
        echo -e "${GREEN}synced${NC}"
        SYNCED=$((SYNCED + 1))
    done

    ok "${SYNCED} project(s) synced to kingdom v${KINGDOM_VERSION}"
}

# ─── Command: promote ─────────────────────────────────────────
cmd_promote() {
    local AGENT_FILE="${1:-}"

    if [ -z "$AGENT_FILE" ] || [ ! -f "$AGENT_FILE" ]; then
        err "Usage: ./kingdom promote <agent-file.md>"
        err "  File not found: ${AGENT_FILE}"
        err "  (use --role king to promote as royal agent)"
        exit 1
    fi

    local AGENT_NAME="$(basename "$AGENT_FILE" .md)"
    local ROLE="${2:-knights}"  # default: knights

    # Auto-detect role from content
    if grep -qi "always running\|always-run\|never stop\|king-sisyphus\|supreme orchestrator" "$AGENT_FILE" 2>/dev/null; then
        ROLE="king"
    elif grep -qi "reports to.*@prince\|serves @prince\|sub-agent of @prince\|sub-agent of @queen\|serves @queen" "$AGENT_FILE" 2>/dev/null; then
        ROLE="knights"
    fi

    header "Promote: ${AGENT_NAME}"
    info "Role: ${ROLE}"
    info "From: ${AGENT_FILE}"

    # Strength check
    local LINES=$(wc -l < "$AGENT_FILE")
    local SCORE=0
    grep -qi "I am\|I'm\|role\|purpose\|responsibilit" "$AGENT_FILE" && SCORE=$((SCORE + 2))
    grep -qi "workflow\|flow\|how to\|steps\|procedure" "$AGENT_FILE" && SCORE=$((SCORE + 2))
    grep -qi "^##.*rule\|- Never\|- Always\|- Only\|^##.*constraint" "$AGENT_FILE" && SCORE=$((SCORE + 2))
    grep -qi "output\|example\|format\|template\|report" "$AGENT_FILE" && SCORE=$((SCORE + 1))
    [ "$LINES" -ge 15 ] && [ "$LINES" -le 100 ] && SCORE=$((SCORE + 1))
    # Penalty for project-specific references
    grep -qi "{{project_name}}\|this project specifically\|this repo\|this codebase" "$AGENT_FILE" && SCORE=$((SCORE - 2))

    echo "   Lines: ${LINES}"
    echo "   Strength: ${SCORE}/8"

    if [ "$SCORE" -lt 4 ]; then
        warn "Score ${SCORE}/8 — below threshold. This agent may be too weak or project-specific."
        warn "Use --force to promote anyway."
        exit 1
    fi

    local DEST="$KINGDOM_DIR/$ROLE/$AGENT_NAME.md"
    if [ -f "$DEST" ]; then
        warn "Agent '${AGENT_NAME}' already exists in ${ROLE}/"
        warn "Use --force to overwrite"
        exit 1
    fi

    cp "$AGENT_FILE" "$DEST"
    ok "Promoted → ${DEST}"
    info "Register in opencode.kingdom.json and run: ./kingdom backup && ./kingdom sync"
}

# ─── Main Router ──────────────────────────────────────────────
main() {
    local CMD="${1:-help}"
    shift 2>/dev/null || true

    case "$CMD" in
        init|initialize)
            cmd_init "$@"
            ;;
        link|include|add)
            cmd_link "$@"
            ;;
        promote|promote-agent)
            cmd_promote "$@"
            ;;
        backup|mirror)
            cmd_backup
            ;;
        restore|regenerate|recover)
            cmd_restore
            ;;
        sync|update|push)
            cmd_sync "$@"
            ;;
        status|info)
            cmd_status
            ;;
        version|--version|-v)
            cmd_version
            ;;
        help|--help|-h|"")
            show_help
            ;;
        *)
            err "Unknown command: ${CMD}"
            echo "Run: ./kingdom help"
            exit 1
            ;;
    esac
}

main "$@"
